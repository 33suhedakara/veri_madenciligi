        "# pandas kütüphanesini veri analizi için içe aktarır\n",
        "import pandas as pd\n",
        "# numpy kütüphanesini sayısal işlemler için içe aktarır\n",
        "import numpy as np\n",
        "# matplotlib kütüphanesinin pyplot modülünü grafik çizmek için yükler\n",
        "import matplotlib.pyplot as plt\n",
        "# sklearn kütüphanesinden lineer regresyon modelini yükler\n",
        "from sklearn.linear_model import LinearRegression\n",
        "# model performansını ölçmek için hata metriğini yükler\n",
        "from sklearn.metrics import mean_squared_error\n",
        "\n",
        "\n",
        "# 1) sözlük yapısında veri tanımlama\n",
        "data = {\n",
        "    \"Ogrenci\": [\"Ayse\", \"Ece\", \"Mert\", \"Asli\", \"Ali\", \"Hatice\", \"Burak\", \"Zehra\", \"Ahmet\"],\n",
        "    \"Vize\": [45, 85, 30, 90, 65, 30, 40, 60, 70],\n",
        "    \"Final\": [55, 90, 40, 80, 70, 50, 80, 60, 75]\n",
        "}\n",
        "\n",
        "# 2) Sözlüğü DataFrame'e (tabloya) çevirme\n",
        "df = pd.DataFrame(data)\n",
        "print(\"Veri seti:\")\n",
        "print(df)\n",
        "\n",
        "# 3) Ortalama hesaplayan fonksiyon tanımlama\n",
        "def ortalama_hesapla(vize, final):\n",
        "    return (vize * 0.4) + (final * 0.6)\n",
        "\n",
        "# 4) Fonksiyonu kullanarak tek seferde 'Ortalama' sütunu ekleme\n",
        "df[\"Ortalama\"] = ortalama_hesapla(df[\"Vize\"], df[\"Final\"])\n",
        "\n",
        "# 5) Döngü ve Koşul (if-else) ile Geçti/Kaldı durumunu belirleme\n",
        "durumlar = []\n",
        "for ort in df[\"Ortalama\"]:\n",
        "    if ort >= 70:\n",
        "        durumlar.append(\"Geçti\")\n",
        "    else:\n",
        "        durumlar.append(\"Kaldı\")\n",
        "df[\"Durum\"] = durumlar\n",
        "print(\"Ödev Sonuç Listesi:\")\n",
        "print(df)\n",
        "\n",
        "# 6) Sadece 'Geçti' dolan öğrncileri filtreleme\n",
        "gecenler = df[df[\"Durum\"] == \"Geçti\"]\n",
        "\n",
        "# 7) Vize notu 80'den büyük olanları filtreleme\n",
        "yuksek_vize = df[df[\"Vize\"] > 80]\n",
        "\n",
        "print(\"Geçen Öğrenciler:\")\n",
        "print(gecenler)\n",
        "\n",
        "# 8) Veri setindeki sayısal sütunların (vize, final, ortalama) özetini verir\n",
        "istatistiksel_ozet = df.describe()\n",
        "\n",
        "# 9) Sadece belirli bir sütunun ortalamasını alma\n",
        "ortalama_vize = df[\"Vize\"].mean()\n",
        "\n",
        "print(\"Verinin Genel İstatistikleri:\")\n",
        "print(istatistiksel_ozet)\n",
        "print(f\"\\nTüm sınıfın vize ortalaması: {ortalama_vize}\")\n",
        "\n",
        "# 10)Ortalamaya göre sıralama (ascending=False büyükten küçüğe)\n",
        "basari_siralamasi = df.sort_values(by=\"Ortalama\", ascending=False)\n",
        "\n",
        "print(\"Başarı Sıralaması:\")\n",
        "print(basari_siralamasi)\n",
        "\n",
        "\n",
        "# 11) görselleştirme:(sütun) grafiği (plt.bar)\n",
        "plt.bar(df[\"Ogrenci\"], df[\"Ortalama\"], color='red')\n",
        "plt.xlabel(\"Öğrenciler\")\n",
        "plt.ylabel(\"Ortalamalar\")\n",
        "plt.title(\"Sınıfın Not Dağılımı\")\n",
        "plt.show()\n",
        "\n",
        "# Saçılım grafiği oluşturma (plt.scatter)\n",
        "plt.scatter(df[\"Vize\"], df[\"Final\"])\n",
        "\n",
        "# x ekseninin etiketini belirleme\n",
        "plt.xlabel(\"Vize\")\n",
        "\n",
        "# y ekseninin etiketini belirleme\n",
        "plt.ylabel(\"Final\")\n",
        "\n",
        "# grafiğe başlık ekleme\n",
        "plt.title(\"Vize ve Final Notu İlişkisi\")\n",
        "\n",
        "# oluşturulan grafiği ekranda gösterir\n",
        "plt.show()\n",
        "\n",
        "# bağımsız değişken olarak Vize seçme\n",
        "X = df[[\"Vize\"]]\n",
        "\n",
        "# bağımlı değişken olarak Final seçme\n",
        "y = df[\"Final\"]"
      ]
